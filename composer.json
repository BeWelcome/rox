{
    "name": "bewelcome/rox",
    "description": "The source code that drives bewelcome.org",
    "homepage": "https://www.bewelcome.org/",
    "type": "project",
    "license": "GPL",
    "require": {
        "ext-exif": "*",
        "ext-fileinfo": "*",
        "ext-gd": "*",
        "ext-intl": "*",
        "ext-json": "*",
