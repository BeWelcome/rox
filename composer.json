        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "ext-session": "*",
        "ext-xsl": "*",
        "ext-zip": "*",
        "amphp/http-client": "^5.2",
        "anthonymartin/geo-location": "^2.0",
