{% extends 'base.html.twig' %}
{% import 'macros.twig' as macros %}

{% block javascripts %}
<script type="text/javascript">
    const checkAllSpam = document.getElementById('checkAllSpam');
    const checkAllNoSpam  = document.getElementById('checkAllNoSpam');
    const spam = document.querySelectorAll('.checkableSpam');
    const noSpam = document.querySelectorAll('.checkableNoSpam');
    checkAllSpam.addEventListener('click', function() {
        const status = checkAllSpam.checked;
        spam.forEach((checkbox) => {checkbox.checked = status;});
        if (status) {
            checkAllNoSpam.checked = false;
            noSpam.forEach((checkbox) => {checkbox.checked = false;});
        }
    });
    checkAllNoSpam.addEventListener('click', function() {
        console.log(checkAllNoSpam.checked);
        const status = checkAllNoSpam.checked;
        noSpam.forEach((checkbox) => {checkbox.checked = status;});
        if (status) {
            checkAllSpam.checked = false;
            spam.forEach((checkbox) => {checkbox.checked = false;});
        }
    });
</script>
{% endblock %}

{% block content %}
    {% if reported.nbResults == 0 %}
        <div class="alert alert-warning">{{ 'admin.checker.no.messages' | trans }}</div>
    {% else %}
        {{ form_start(form) }}
        {{ form_errors(form) }}
        {% if reported.haveToPaginate %}
            <div class="float-left">
                {{ pagerfanta( reported, 'rox_default') }}
            </div>
        {% endif %}
        <table class="table table-striped table-hover">

            <tr>
                <th>Sender</th>
                <th>Message</th>
                <th>Receiver</th>
                <th>Created</th>
                <th>Comment</th>
                <th style="writing-mode: vertical-lr">ok</th>
                <th style="writing-mode: vertical-lr">spam</th>
            </tr>
            <tr>
                <td colspan="5">&nbsp;</td>
                <td><div class="o-checkbox"><input type="checkbox" id="checkAllNoSpam" class="o-checkbox__input"><label class="o-checkbox__label"></label></div></td>
                <td><div class="o-checkbox"><input type="checkbox" id="checkAllSpam" class="o-checkbox__input"><label class="o-checkbox__label"></label></div></td>
            </tr>
        {% for message in reported.currentPageResults %}
            <tr>
                <td>{{ macros.avatarstack(message.Sender.Username, 30) }}<br>
                    <small class="text-muted">{{ ('memberstatus' ~ message.Sender.Status)|lower|trans }}</small></td>
                <td><strong>{{ message.subject.subject }}</strong>&nbsp;{% if message.request is null %}<i class="fa fa-envelope"></i>{% else %}<i class="fa fa-bed"></i>{% endif %}<br>
                    {{ message.Message|purify }}</td>
                <td>{{ macros.avatarstack(message.Receiver.Username, 30) }}<br>
                    <small class="text-muted">{{ ('memberstatus' ~ message.Receiver.Status)|lower|trans }}</small></td>
                <td>{{ message.created.DiffForHumans }}<br>
                ({{  message.created | format_datetime('short', 'short') }})</td>
                <td>{{ message.checkerComment }}</td>
                <td>{{ form_widget(form.noSpamMessages[loop.index0], {'attr': {'class': 'checkableNoSpam'}}) }}</td>
                <td>{{ form_widget(form.spamMessages[loop.index0], {'attr': {'class': 'checkableSpam'}}) }}</td>
            </tr>
        {% endfor %}
        </table>
        <div class="row">
            <div class="col-12 text-right">
                <button type="submit" class="btn btn-primary">{{ 'button.update' | trans }}</button>
            </div>
        </div>
        {% if reported.haveToPaginate %}
            <div class="float-left">
                {{ pagerfanta( reported, 'rox_default') }}
            </div>
        {% endif %}
        {{ form_rest(form) }}
        {{ form_end(form) }}
    {% endif %}
{% endblock %}
