{% block ckeditor_widget %}
    {% if image_upload %}
        {% set attr = attr|merge({class: (attr.class|default('') ~ ' js-ckeditor-images')|trim}) %}
    {% else %}
        {% set attr = attr|merge({class: (attr.class|default('') ~ ' js-ckeditor-no-images')|trim}) %}
    {% endif %}
    <textarea {{ block('widget_attributes') }}>{{ value }}</textarea>
    {% if not async %}
        {{ block( '_ckeditor_javascript' ) }}
        {{ block( '_ckeditor_stylesheet' ) }}
    {% endif %}
{% endblock %}

{% block _ckeditor_javascript %}
    {{ encore_entry_script_tags('roxeditor') }}
{% endblock %}

{% block _ckeditor_stylesheet %}
    {{ encore_entry_link_tags('roxeditor') }}
    <style>
        .ck-editor__editable {
            min-height: 10em;
        }
    </style>
{% endblock %}

