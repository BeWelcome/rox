{# Guest-only footer for the public homepage: same visual system as footer.html.twig but no member-only community links (avoids login walls for visitors). #}
<footer>
    <div id="footer_content" class="stickyfooter">
        <div class="stickyfooter__main">
            <div class="container-fluid stickyfooter-container">
                <div class="row align-items-lg-start footer-modern-nav">
                    <div class="col-12 col-md-6 col-lg-4 mb-4 mb-lg-0">
                        <h2 class="footer-modern-heading">
                            <i class="fa fa-user-shield footer-modern-heading__icon" aria-hidden="true"></i>{{ 'safety' | trans }}
                        </h2>
                        <ul class="list-unstyled footer-modern-list mb-0">
                            <li><a href="{{ url('safety') }}">{{ 'menu.safety.information' | trans }}</a></li>
                            <li><a href="{{ url('safety_contact_no_modal') }}">{{ 'menu.safety.report' | trans }}</a></li>
                        </ul>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mb-4 mb-lg-0">
                        <h2 class="footer-modern-heading">
                            <i class="fa fa-question-circle footer-modern-heading__icon" aria-hidden="true"></i>{{ 'getanswers' | trans }}
                        </h2>
                        <ul class="list-unstyled footer-modern-list footer-modern-list--legal mb-0">
                            <li><a href="{{ url('about') }}">{{ 'aboutuspage' | trans }}</a></li>
                            <li><a href="{{ url('about_faq') }}">{{ 'faq' | trans }}</a></li>
                            <li><a href="{{ url('feedback') }}">{{ 'contactus' | trans }}</a></li>
                            <li><a href="{{ url('feedback', { IdCategory: 1, RequestURI: url('homepage')}) }}">{{ 'footer.reportbug' | trans }}</a></li>
                        </ul>
                    </div>
                    <div class="col-12 col-md-6 col-lg-4 mb-4 mb-lg-0">
                        <h2 class="footer-modern-heading">
                            <i class="fa fa-balance-scale footer-modern-heading__icon" aria-hidden="true"></i>{{ 'landing.beinformed.title' | trans }}
                        </h2>
                        <ul class="list-unstyled footer-modern-list mb-0">
                            <li><a href="{{ url('terms_of_use') }}" target="_blank" rel="noopener noreferrer">{{ 'termsofuse' | trans }}</a></li>
                            <li><a href="{{ url('privacy_policy') }}" target="_blank" rel="noopener noreferrer">{{ 'privacy' | trans }}</a></li>
                            <li><a href="{{ url('data_rights') }}" target="_blank" rel="noopener noreferrer">{{ 'datarights' | trans }}</a></li>
                            <li><a href="{{ url('imprint') }}">{{ 'impressum' | trans }}</a></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="footer-bottom-band">
            <div class="container-fluid stickyfooter-container">
                <div class="row align-items-center footer-bottom-band__row">
                    <div class="col-12 col-md-7 col-lg-8 footer-bottom-band__legal">
                        <div class="footer-modern-meta">
                            &copy; 2007 &mdash; {{ "now" | date("Y") }} <a href="https://www.bevolunteer.org/"
                                                                           target="_blank">BeVolunteer</a> and contributors

                            - <em>Running on open source <a class="d-inline" href="https://github.com/bewelcome/rox">BW
                                    Rox</a> rev. <a
                                        href="https://github.com/BeWelcome/rox/commit/{{ version }}">{{ version }}</a>
                                ({{ version_dt }})</em>
                        </div>
                    </div>
                    <div class="col-12 col-md-5 col-lg-4 footer-bottom-band__lang">
                        <form method="post" class="footer-bottom-band__lang-form">
                            <div class="form-row align-items-center">
                                <div class="col-12 col-md-auto">
                                    <label for="language" class="col-form-label mb-0 d-block footer-bottom-band__lang-label">
                                        {{ 'footer.site.language' | trans }}
                                    </label>
                                </div>
                                <div class="col-12 col-md-auto footer-bottom-band__lang-select-wrap">
                                    <select id="language" name="language" class="form-control-sm select2 footer-site-language"
                                            onchange="window.location.href=this.value; return false">
                                        {% for lang in locales %}
                                            <option {% if lang == app.request.locale %}selected="selected"{% endif %}
                                                    value="{{ path('language', { locale: lang }) }}">{{ language_name(lang) }}
                                                ({{ language_name_translated(lang, app.request.locale) }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>
