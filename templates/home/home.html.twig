<!DOCTYPE html>
<html lang="{{ locale }}" dir="auto">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="{{ asset('/images/favicon-96x96.png') }}" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="{{ asset('/images/favicon.svg') }}" />
    <link rel="shortcut icon" href="{{ asset('/images/favicon.ico') }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('/images/apple-touch-icon.png') }}" />
    <meta name="apple-mobile-web-app-title" content="beWelcome" />

    <title>BeWelcome - {{ 'home.headline.bewelcome.cultural' | trans }}</title>
    <meta name="description" content="{{ 'default_meta_description' | trans }}"/>
    <meta name="keywords" content="{{ 'default_meta_keyword' | trans }}"/>

    {% include 'webpreview.html.twig' %}

    {{ encore_entry_link_tags('home') }}
    {{ encore_entry_link_tags('tailwind') }}
    {{ encore_entry_link_tags('leaflet') }}
    <link rel='manifest' href='{{ asset('manifest.webmanifest') }}'>
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/service-worker.js').then(registration => {
                    console.log('SW registered: ', registration);
                }).catch(registrationError => {
                    console.log('SW registration failed: ', registrationError);
                });
            });
        }
    </script>
</head>
<body>
{% block content %}
{% include 'loginbar.html.twig' with { slim_nav: true } %}

<main class="home-landing">
    <section class="home-hero" aria-labelledby="home-hero-title">
        <div class="home-hero__media" aria-hidden="true">
            <video class="home-hero__video"
                   autoplay
                   muted
                   playsinline
                   preload="metadata"
                   poster="{{ asset(images[1].high) }}">
                <source src="{{ asset('video/hero.mp4') }}" type="video/mp4">
            </video>
        </div>
        <div class="home-hero__body">
            <div class="container home-hero__container px-3 px-sm-4">
                <div class="row home-hero__row justify-content-center align-items-start">
                    <div class="col-12 col-lg-7 col-xl-6 home-hero__copy text-center text-lg-left mb-4 mb-lg-0">
                        <h1 id="home-hero-title" class="home-heading">
                            <span class="home-heading__brand">
                                <img class="home-heading__logo" src="{{ asset('images/favicon.svg') }}" alt="BeWelcome">
                                <span class="home-heading__name">BeWelcome</span>
                            </span>
                            <span class="home-heading__subtitle">the largest free hospitality community</span>
                        </h1>
                        <p class="home-hero__abstract text-white">{{ 'home.abstract.bewelcome.cultural' | trans }}</p>
                        <p class="home-hero__lead text-white">{{ 'home.bewelcome.free' | trans | escape | replace({
                            '%link_start%': '<a class="home-hero__link" href="' ~ path('wiki_page', { pageTitle: 'Can BeWelcome be sold' }) ~ '">',
                            '%link_end%': '</a>'
                        }) | raw }}</p>
                        <div class="home-hero__actions">
                            <a href="{{ url('signup') }}" class="btn home-hero__cta">{{ 'home.button.join' | trans }}</a>
                            <button type="button" class="btn home-hero__login-btn d-lg-none js-home-login-open" aria-controls="home-login" aria-expanded="false">
                                <i class="fas fa-user" aria-hidden="true"></i>
                                {{ 'login' | trans }}
                            </button>
                        </div>
                    </div>
                    <div class="col-12 col-lg-5 col-xl-5 home-hero__aside js-home-login-aside">
                        <aside id="home-login" class="home-login-panel" aria-label="{{ 'login' | trans }}">
                            <button type="button" class="home-login-panel__close d-lg-none js-home-login-close" aria-label="{{ 'close' | trans }}">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                                    <line x1="18" y1="6" x2="6" y2="18"></line>
                                    <line x1="6" y1="6" x2="18" y2="18"></line>
                                </svg>
                            </button>
                            <h2 class="home-login-panel__title">{{ 'login' | trans }}</h2>
                            {% include 'partials/home_login_form.html.twig' %}
                            <p class="home-login-panel__signup">{{ 'menu.not.a.member.yet' | trans }}
                                <a href="{{ url('signup') }}">{{ 'navbar.button.signup' | trans }}</a>
                            </p>
                        </aside>
                    </div>
                </div>
            </div>
            <div class="home-login-backdrop js-home-login-backdrop" aria-hidden="true"></div>
        </div>
    </section>

    <section id="about">
        <div class="container home-about__container">
            <div class="row justify-content-center">
                <div class="col-12 text-center mb-4 mb-lg-5">
                    <h2 class="home-section-title">{{ 'tourpage' | trans }}</h2>
                </div>
            </div>
            <div class="row justify-content-center home-features__row">
                <div class="col-12 col-md-6 col-lg-3 home-feature-card">
                    <div class="home-feature-card__icon"><i class="far fa-handshake" aria-hidden="true"></i></div>
                    <h3 class="home-feature-card__title">{{ 'tour_link_meet' | trans }}</h3>
                    <p class="home-feature-card__text">{{ 'tourpage_text3' | trans }}</p>
                </div>
                <div class="col-12 col-md-6 col-lg-3 home-feature-card">
                    <div class="home-feature-card__icon"><i class="fa fa-map-signs" aria-hidden="true"></i></div>
                    <h3 class="home-feature-card__title">{{ 'tour_link_travel' | trans }}</h3>
                    <p class="home-feature-card__text">{{ 'tourpage_text4' | trans }}</p>
                </div>
                <div class="col-12 col-md-6 col-lg-3 home-feature-card">
                    <div class="home-feature-card__icon"><i class="fa fa-home" aria-hidden="true"></i></div>
                    <h3 class="home-feature-card__title">{{ 'tour_link_host' | trans }}</h3>
                    <p class="home-feature-card__text">{{ 'tourpage_text5' | trans }}</p>
                </div>
                <div class="col-12 col-md-6 col-lg-3 home-feature-card">
                    <div class="home-feature-card__icon"><i class="far fa-heart" aria-hidden="true"></i></div>
                    <h3 class="home-feature-card__title">{{ 'tour_link_share' | trans }}</h3>
                    <p class="home-feature-card__text">{{ 'tourpage_text2' | trans }}</p>
                </div>
            </div>
        </div>
    </section>

    <section class="home-strip" aria-labelledby="home-strip-hosts-title">
        <div class="home-strip__media" aria-hidden="true">
            <img class="home-strip__img"
                 srcset="{{ asset(images[2].high) }} 1200w, {{ asset(images[2].low) }} 576w"
                 src="{{ asset(images[2].high) }}"
                 alt="">
        </div>
        <div class="home-strip__body container py-5 text-center">
            <h2 id="home-strip-hosts-title" class="home-heading">{{ 'home.headline.find.hosts' | trans }}</h2>
        </div>
    </section>

    <section id="statistics">
        <div class="container home-stats__container">
            <h2 class="home-section-title mb-4 mb-lg-5">{{ 'home.header.statistics' | trans }}</h2>
            <div class="row justify-content-center home-stats__row">
                <div class="col-6 col-md-4 col-lg home-stat-item">
                    <i class="far fa-user home-stat-item__icon" aria-hidden="true"></i>
                    <div class="home-stat-value">{{ stats.members }}</div>
                    <div class="home-stat-label">{{ 'home.stats.members' | trans }}</div>
                </div>
                <div class="col-6 col-md-4 col-lg home-stat-item">
                    <i class="far fa-flag home-stat-item__icon" aria-hidden="true"></i>
                    <div class="home-stat-value">{{ stats.countries }}</div>
                    <div class="home-stat-label">{{ 'home.stats.countries' | trans }}</div>
                </div>
                <div class="col-6 col-md-4 col-lg home-stat-item">
                    <i class="fa fa-language home-stat-item__icon" aria-hidden="true"></i>
                    <div class="home-stat-value">{{ stats.languages }}</div>
                    <div class="home-stat-label">{{ 'home.stats.languages' | trans }}</div>
                </div>
                <div class="col-6 col-md-4 col-lg home-stat-item">
                    <i class="far fa-smile home-stat-item__icon" aria-hidden="true"></i>
                    <div class="home-stat-value">{{ stats.comments }}</div>
                    <div class="home-stat-label">{{ 'home.stats.positive_comments' | trans }}</div>
                </div>
                <div class="col-6 col-md-4 col-lg home-stat-item">
                    <i class="far fa-calendar-check home-stat-item__icon" aria-hidden="true"></i>
                    <div class="home-stat-value">{{ stats.activities }}</div>
                    <div class="home-stat-label">{{ 'home.stats.activities' | trans }}</div>
                </div>
            </div>
        </div>
    </section>

    <section class="home-strip home-strip--cta home-cta" aria-labelledby="home-cta-title">
        <div class="home-strip__media" aria-hidden="true">
            <img class="home-strip__img"
                 srcset="{{ asset(images[3].high) }} 1200w, {{ asset(images[3].low) }} 576w"
                 src="{{ asset(images[3].high) }}"
                 alt="">
        </div>
        <div class="home-strip__body container">
            <h2 id="home-cta-title" class="home-cta-heading">{{ 'home.title.onestep' | trans }}</h2>
            <p class="home-subheading">{{ 'home.title.onestep.sub' | trans }}</p>
            <div class="text-center">
                <a href="{{ url('signup') }}" class="btn home-cta__button">{{ 'home.button.join' | trans }}</a>
            </div>
        </div>
    </section>
</main>

{% include 'footer.html.twig' %}

{{ encore_entry_script_tags('home') }}
{{ encore_entry_script_tags('jquery_ui') }}
{{ encore_entry_script_tags('password/showhide') }}
<script>
    window.addEventListener("load", function () {
        let locale = document.getElementsByTagName('html')[0].getAttribute('lang');
        let privacyUrl = "/privacy";
        if ('fr' === locale) {
            privacyUrl += "/fr";
        }
        window.cookieconsent.initialise({
            "palette": {
                "popup": {
                    "background": "#ffffff",
                    "text": "#334155"
                },
                "button": {
                    "background": "#f37000",
                    "text": "#ffffff"
                }
            },
            "theme": "edgeless",
            "position": "bottom",
            "content": {
                "href": privacyUrl,
                message: "{{ 'cookie.consent.message'|trans }}",
                dismiss: "{{ 'cookie.consent.dismiss'|trans }}",
                link: "{{ 'cookie.consent.learnmore'|trans }}"
            }
        })
    });
</script>
{% endblock content %}
</body>
</html>
