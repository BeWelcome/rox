{# Primary site navigation. Expects: loggedInMember, teams (Twig globals). #}
{% set slim_nav = slim_nav|default(false) %}
<nav id="main_menu" class="navbar sticky-top navbar-dark navbar-expand bg-primary justify-content-between{% if slim_nav %} loginbar--slim{% endif %}">
    <div class="container-lg bw-topbar__container">
        <ul id="collapsing_menu" class="navbar navbar-nav">
            <li class="nav-item">
                <a id="brand_image" class="navbar-brand" href="{{ url('homepage') }}">
                    {% include 'logo.html.twig' %}
                </a>
            </li>
        </ul>
        <ul id="static_menu" class="navbar navbar-nav align-items-center">
            {% if loggedInMember %}
            {% if teams|length != 0 %}
            <li class="nav-item dropdown">
                <a id="volunteer_menu_toggle" href="#volunteer_menu" class="nav-link dropdown-toggle topbar-icon-dropdown"
                   data-target="volunteer_menu" data-toggle="dropdown" data-dropdown-click-only aria-haspopup="true" aria-expanded="false"
                   aria-label="{{ 'volunteer' | trans }}">
                    <span class="topbar-icon-dropdown__icon" aria-hidden="true"><i class="fas fa-handshake"></i></span>
                </a>
                <ul id="volunteer_menu" class="dropdown-menu dropdown-menu-right nav-top-dropdown" role="menu">
                    <li class="member-menu__toolbar d-flex d-xl-none">
                        <button type="button" class="member-menu__close" aria-label="{{ 'close' | trans }}">
                            <span class="member-menu__close-icon" aria-hidden="true">&times;</span>
                        </button>
                    </li>
                    <li class="nav-top-dropdown__title d-xl-none">
                        <h6 class="dropdown-header text-left mb-0">{{ 'volunteer' | trans }}</h6>
                    </li>
                    {% for team in teams %}
                        <li>
                            {% if team.route starts with '/' %}
                                <a href="{{ team.route }}" class="dropdown-item text-left">{{ team.trans | trans }}</a>
                            {% else %}
                                <a href="{{ path(team.route) }}" class="dropdown-item text-left">{{ team.trans | trans }}</a>
                            {% endif %}
                        </li>
                    {% endfor %}
                    <li>
                        <a href="{{ url('getactive') }}" class="dropdown-item text-left">{{ 'about_getactive' | trans }}</a>
                    </li>
                </ul>
            </li>
            {% endif %}
            <li class="nav-item dropdown">
                <a id="search_menu_toggle" href="#search_menu" class="nav-link dropdown-toggle topbar-icon-dropdown"
                   data-target="search_menu" data-toggle="dropdown" data-dropdown-click-only aria-haspopup="true" aria-expanded="false"
                   aria-label="{{ 'findmembers' | trans }}">
                    <span class="topbar-icon-dropdown__icon" aria-hidden="true"><i class="fas fa-search"></i></span>
                </a>
                <ul id="search_menu" class="dropdown-menu dropdown-menu-right nav-top-dropdown" role="menu">
                    <li class="member-menu__toolbar member-menu__toolbar--with-title d-flex d-xl-none">
                        <h6 class="member-menu__toolbar-title mb-0">{{ 'findmembers' | trans }}</h6>
                        <button type="button" class="member-menu__close" aria-label="{{ 'close' | trans }}">
                            <span class="member-menu__close-icon" aria-hidden="true">&times;</span>
                        </button>
                    </li>
                    <li><a href="{{ url( 'search_locations' ) }}" class="dropdown-item text-left">{{ 'search.locations' | trans }}</a></li>
                    <li><a href="{{ path('search_members') }}" class="dropdown-item text-left">{{ 'search.members' | trans }}</a></li>
                    <li><a href="{{ url('places') }}" class="dropdown-item text-left">{{ 'browsecountries' | trans }}</a></li>
                    <li><a href="{{ url('visitors') }}" class="dropdown-item text-left">{{ 'menu.visitors' | trans }}</a></li>
                </ul>
            </li>
            <li class="nav-item dropdown">
                <a id="community_menu_toggle" href="#community_menu" class="nav-link dropdown-toggle topbar-icon-dropdown"
                   data-target="community_menu" data-toggle="dropdown" data-dropdown-click-only aria-haspopup="true" aria-expanded="false"
                   aria-label="{{ 'communitymenu' | trans }}">
                    <span class="topbar-icon-dropdown__icon" aria-hidden="true"><i class="fas fa-users"></i></span>
                </a>
                <ul id="community_menu" class="dropdown-menu dropdown-menu-right nav-top-dropdown" role="menu">
                    <li class="member-menu__toolbar member-menu__toolbar--with-title d-flex d-xl-none">
                        <h6 class="member-menu__toolbar-title mb-0">{{ 'communitymenu' | trans }}</h6>
                        <button type="button" class="member-menu__close" aria-label="{{ 'close' | trans }}">
                            <span class="member-menu__close-icon" aria-hidden="true">&times;</span>
                        </button>
                    </li>
                    {% include 'layout/_community_nav_links.html.twig' with { item_link_class: 'text-left' } only %}
                </ul>
            </li>
            {# conversations #}
            <li class="nav-item topbar-messages">
                <div id="conversationCount" class="nav-link topbar-counter px-0" data-count="-1">
                    <a href="{{ path('conversations', {'conversationsType': 'conversations'}) }}" aria-label="{{ 'conversations' | trans }}" class="topbar-counter__link text-white">
                        <span class="topbar-counter__icon" aria-hidden="true"><i class="fas fa-envelope"></i></span>
                        <span class="badge topbar-counter__badge"><i class="fa fa-fw fa-spinner"></i></span>
                    </a>
                </div>
            </li>

            <li class="nav-item dropdown">
                <a id="member_menu_toggle" href="#member_menu" class="nav-link dropdown-toggle topbar-member-toggle"
                   data-target="member_menu" data-toggle="dropdown" data-dropdown-click-only aria-haspopup="true" aria-expanded="false" aria-label="{{ 'profile' | trans }}">
                    <img class="profileimg px-0 js-profile-picture" src="{{ url('avatar', { username: loggedInMember.username, size: 36 })}}" width="32" height="32" alt="{{ 'profile.picture' }}">
                    <span class="d-none d-md-inline topbar-member__name">{{ loggedInMember.Username }}</span>
                </a>
                <ul id="member_menu" class="dropdown-menu dropdown-menu-right member-menu" role="menu">
                    {# Close: full-screen sheet below xl. #}
                    <li class="member-menu__toolbar d-flex d-xl-none">
                        <button type="button" class="member-menu__close" aria-label="{{ 'close' | trans }}">
                            <span class="member-menu__close-icon" aria-hidden="true">&times;</span>
                        </button>
                    </li>
                    <li><a
                            href="{{ path( 'members_profile' , {username: loggedInMember.username} ) }}"
                            class="dropdown-item text-left">{{ 'profile' | trans }}</a></li>
                    <li><a href="{{ path('profile_edit', {username: loggedInMember.username}) }}"
                                              class="dropdown-item text-left">{{ 'profile.menu.edit.profile' | trans }}</a></li>
                    <li><a href="{{ path('preferences', {'username': loggedInMember.username}) }}"
                                              class="dropdown-item text-left">{{ 'profile.menu.preferences' | trans }}</a></li>
                    <li><a href="{{ path('notes', {'username': loggedInMember.username}) }}"
                                              class="dropdown-item text-left">{{ 'profile.menu.my.notes' | trans }}</a></li>
                    <li><a href="{{ url('trips') }}" class="dropdown-item text-left">{{ 'trips.mytrips' | trans }}</a></li>
                    <li><a href="{{ path('change_password', {'username': loggedInMember.username}) }}"
                                              class="dropdown-item text-left">{{ 'profile.change.password.menu' | trans }}</a></li>
                    <li><div class="dropdown-divider"></div></li>
                    <li class="member-menu__logout-item">
                        <a href="{{ url('_logout_main') }}" class="member-menu__logout">
                            <span class="member-menu__logout-icon" aria-hidden="true"><i class="fas fa-sign-out-alt"></i></span>
                            <span class="member-menu__logout-text">{{ 'logout' | trans }}</span>
                        </a>
                    </li>
                </ul>
            </li>
            {% endif %}
        </ul>
    </div>
</nav>
