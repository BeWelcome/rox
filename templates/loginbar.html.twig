{% import 'macros.twig' as macros %}
<nav id="main_menu" class="navbar sticky-top navbar-dark navbar-expand bg-primary justify-content-between">
    <div class="container-lg">
        <ul id="collapsing_menu" class="navbar navbar-nav">
            <li class="nav-item">
                <a id="brand_image" class="navbar-brand" href="{{ url('homepage') }}">
                    {% include 'logo.html.twig' %}
                </a>
            </li>
            {% include 'login_form_navbar.html.twig' %}
        </ul>
        <ul id="static_menu" class="navbar navbar-nav">
            {% include 'login_form_dropdown.html.twig' %}
            <li class="nav-item dropdown">
                <button class="btn btn-primary border text-nowrap dropdown-toggle" data-toggle="dropdown" aria-haspopup="true" aria-expanded="false" aria-label="{{ 'menu.language.toggle'|trans }}">{{ language_name(app.request.locale) }}</button>
                <div id="language_dropdown" class="dropdown-menu dropdown-menu-right u:w-150 u:md:w-300 u:max-h-[50vh] u:overscroll-contain u:overflow-y-auto">
                    <div class="u:grid u:grid-cols-1 u:md:gap-8 u:md:grid-cols-2 u:p-8">
                    {% for lang in locales %}
                        <a class="dropdown-item {% if lang == app.request.locale %}u:bg-bewelcome{% endif %} u:my-4 u:p-4" href="{{ path('language', { locale: lang }) }}">
                                {{ language_name(lang) }}
                            </a>
                    {% endfor %}
                    </div>
                </div>
            </li>
            <li class="nav-item">
                <button class="border bg-primary mr-1 d-none" id="hamburger" type="button" data-toggle="collapse" data-target="#hamburger_collapse" aria-controls="hamburger_collapse" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
            </li>
        </ul>
    </div>
</nav>
<div class="collapse navbar-dark bg-primary" id="hamburger_collapse">
    <div class="container-lg">
        <ul id="hamburger_menu" class="navbar-nav text-right"></ul>
    </div>
</div>
