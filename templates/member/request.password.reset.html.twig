{% import 'macros.twig' as macros %}
<!doctype html>
<html lang="{{ app.request.locale }}">
<head>
    <base href="/">
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link rel="icon" type="image/png" href="{{ asset('/images/favicon-96x96.png') }}" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="{{ asset('/images/favicon.svg') }}"/>
    <link rel="apple-touch-icon" sizes="180x180" href="{{ asset('/images/apple-touch-icon.png') }}"/>
    <meta name="apple-mobile-web-app-title" content="beWelcome"/>

    <title>{{ 'reset.password' | trans }} | BeWelcome</title>

    <meta name="description" content="{{ 'default_meta_description' | trans }}">
    <meta name="keywords" content="{{ 'default_meta_keyword' | trans }}">
    <meta name="robots" content="{{ 'robots' | trans }}">

    {% include 'webpreview.html.twig' %}

    {{ encore_entry_link_tags('bewelcome') }}
    {{ encore_entry_link_tags('tailwind') }}

    <base id="baseuri" href="{{ app.request.schemeAndHttpHost ~ app.request.baseUrl }}">

    <link rel="manifest" href="{{ asset('manifest.webmanifest') }}">
</head>
<body class="p-login__body" style="background-image:url('{{ asset('images/homepicture-big-1.jpg') }}')">
<div class="p-login__overlay" aria-hidden="true"></div>

{% include 'loginbar.html.twig' with { slim_nav: true, slim_cta: 'signup' } %}

<main role="main" class="p-login">
    <noscript>
        <div class="container-lg">
            <div class="alert alert-danger u:mt-16">
                <p class="h5">You need to activate Javascript for bewelcome.org</p>
                <small>Without it some functions won't work.</small>
            </div>
        </div>
    </noscript>

    <div class="container-lg">
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ label }} p-login__flash">{{ message }}</div>
            {% endfor %}
        {% endfor %}
    </div>

    <div class="p-login__shell">
        <header class="p-login__intro">
            <h1 class="p-login__title">{{ 'password.request.headline' | trans }}</h1>
            <p class="p-login__subtitle">{{ 'password.request.subtitle' | trans }}</p>
        </header>

        <section class="p-login__card" aria-labelledby="reset-card-title">
            <h2 id="reset-card-title" class="p-login__card-title">{{ 'reset.password' | trans }}</h2>

            {% if not form.vars.valid %}
                {% for error in form.vars.errors %}
                    <div class="p-login__error alert alert-danger u:mb-16" role="alert">{{ error.message }}</div>
                {% endfor %}
            {% endif %}

            {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'class': 'p-login__form', 'id': 'reset-password-form'}}) }}
                <div class="o-form-group">
                    <label for="{{ form.username.vars.id }}">{{ 'login.username.or.email' | trans }}</label>
                    {{ form_widget(form.username, {'attr': {'class': 'o-input', 'autofocus': 'autofocus', 'autocomplete': 'username', 'required': 'required'}}) }}
                    {% if not form.username.vars.valid %}
                        {% for error in form.username.vars.errors %}
                            <small class="text-danger d-block u:mt-4">{{ error.message }}</small>
                        {% endfor %}
                    {% endif %}
                </div>

                <button type="submit" name="{{ form.reset_password.vars.full_name }}" class="o-button o-button--l o-button--full p-login__submit">
                    {{ 'password.request.submit' | trans }}
                </button>
            {{ form_end(form, {'render_rest': false}) }}

            <div class="p-login__separator" aria-hidden="true"><span>{{ 'menu.already.a.member' | trans }}</span></div>

            <a href="{{ url('security_login') }}" class="o-button o-button--outline o-button--full p-login__signup">
                {{ 'password.request.back.login' | trans }}
            </a>
        </section>
    </div>
</main>

{{ encore_entry_script_tags('bewelcome') }}
</body>
</html>
