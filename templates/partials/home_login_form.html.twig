<form class="home-login-form" method="post" action="{{ url('security_check') }}" id="home-login-form">
    <div class="home-login-field">
        <label class="home-login-field__label" for="home_login_username">{{ 'login.username.or.email' | trans }}</label>
        <input class="home-login-field__input" type="text" id="home_login_username" name="_username"
               autocomplete="username" required
               inputmode="email"
               placeholder="{{ 'username' | trans }}">
    </div>
    <div class="home-login-field home-login-field--password">
        <label class="home-login-field__label" for="home_login_password">{{ 'password' | trans }}</label>
        <div class="home-login-field__password-wrap">
            <input class="home-login-field__input js-password-input" type="password" id="home_login_password" name="_password"
                   autocomplete="current-password" required
                   placeholder="{{ 'login.password' | trans }}">
            <button type="button" class="home-login-field__toggle js-password-show-hide"
                    aria-label="{{ 'password' | trans }}">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path>
                    <circle cx="12" cy="12" r="3"></circle>
                </svg>
            </button>
        </div>
    </div>
    <div class="home-login-field home-login-field--row d-flex align-items-center">
        <input type="checkbox" class="home-login-field__checkbox me-2" id="home_login_remember" name="_remember_me" value="1">
        <label class="home-login-field__remember mb-0" for="home_login_remember">{{ 'stayloggedin' | trans }}</label>
    </div>
    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
    <button type="submit" class="btn home-login-form__submit">{{ 'indexpageloginsubmit' | trans }}</button>
</form>
