{% extends 'profile/edit_subpage.html.twig' %}

{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('profile/preference') }}
{% endblock javascripts %}

{% block subpage_title -%}
  {{ 'profile.preferences'|trans }}
{%- endblock %}

{% block subpage_body %}
  {{ form_start(form, {attr: {class: 'p-preferences-form'}}) }}
  <input type="hidden" id="member" value="{{ member.username }}">

  <div class="p-preferences-list">
    {% for name, child in form.children %}
      {% if not (name starts with '_') %}
        <section class="p-preference-card">
          <div class="p-preference-card__copy">
            <h2 class="p-preference-card__title">{{ child.vars.label|trans }}</h2>
            {{ form_help(child, {help_attr: {class: 'p-preference-card__help'}}) }}
          </div>

          <div class="p-preference-card__control">
            {% if child.vars.choices|length == 2 %}
              <label class="p-preference-toggle" for="{{ child.vars.id }}">
                <span class="p-preference-toggle__label">{{ child.vars.choices|keys|first|trans }}</span>
                <input id="{{ child.vars.id }}"
                       name="{{ child.vars.full_name }}"
                       type="checkbox"
                       class="p-preference-toggle__input preference"
                       value="{{ child.vars.choices|last }}"
                       {% if child.vars.data == child.vars.choices|last %}checked="checked"{% endif %}>
                <span class="p-preference-toggle__track" aria-hidden="true">
                  <span class="p-preference-toggle__thumb"></span>
                </span>
                <span class="p-preference-toggle__label p-preference-toggle__label--active">{{ child.vars.choices|keys|last|trans }}</span>
              </label>
              {% do child.setRendered %}
            {% else %}
              {% set control_class = (child.vars.attr.class|default('') ~ ' p-preference-select')|trim %}
              {{ form_widget(child, {attr: child.vars.attr|merge({class: control_class})}) }}
            {% endif %}
            {{ form_errors(child) }}
          </div>
        </section>
      {% endif %}
    {% endfor %}
  </div>

  {{ form_rest(form) }}
  {{ form_end(form) }}
{% endblock subpage_body %}
