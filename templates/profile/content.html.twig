{% import 'macros.twig' as macros %}

{% set address = member.activeAddress %}
{% set profileTranslation = translated_fields[profile_language] ?? [] %}
<div id="profile-language-{{ profile_language }}"
     class="{% if profile_language != active_locale %}u:hidden! {% endif %}">
  <div class="u:mb-16 u:max-sm:flex u:max-sm:flex-col u:md:block u:md:columns-2">
    {#
    Add cards in order
    'About Me', 'Languages', 'My Interests', 'Travel Experiences', 'Groups', 'Gallery', 'Family and Friends'
    'Accommodation', 'Comments'
    #}
    {% set aboutMe = profileTranslation['AboutMe'] ?? '' %}
    {% set occupation = profileTranslation['Occupation'] ?? '' %}
    <div class="u:md:break-inside-avoid u:order-1 u:mb-16">
      <div class="card u:relative">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.about.me'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'aboutme'}) %}
            {% set edit_text = 'profile.edit.about.me'|trans({}, 'messages', profile_language) %}
            <div>
              <a href="{{ edit_link }}">
                <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
                <span class="u:sr-only">{{ edit_text }}</span>
              </a>
            </div>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          <div class="card-text m-0">
            {% if aboutMe|length != 0 %}
              {{ aboutMe|purify|nl2br }}
            {% else %}
              {% if edit %}
                <div class="h5 u:mt-8 u:mb-0">{{ 'profile.about.me'|trans({}, "messages", profile_language)|raw }}</div>
              {% else %}
                {{ 'profile.no.about.me'|trans({}, "messages", profile_language) }}
              {% endif %}
            {% endif %}
            {% if edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.occupation'|trans({}, "messages", profile_language)|raw }}</div>
              <div>
                {% if occupation|length != 0 %}
                  {{ occupation|purify|nl2br }}
                {% endif %}
              </div>
            {% endif %}
          </div>
          {% set offerHosts =  profileTranslation['OfferHosts'] ?? '' %}
          {% if offerHosts|length > 0 or edit %}
            <div class="stay h5 u:mt-8 u:mb-0">
              {{ 'profile.offer.hosts'|trans({}, "messages", profile_language)|raw }}
            </div>
            {% if offerHosts|length > 0 %}
              <div>{{ profileTranslation['OfferHosts']|purify }}</div>{% endif %}
          {% endif %}
        </div>
      </div>
    </div>

    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'languages.spoken'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_languages', {username: member.username, language: profile_language}) %}
            {% set edit_text = 'profile.edit.languages'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          <div class="card-text m-0">
            {% for languageLevel in language_levels %}
              <p class="m-0">
                {{ ('lang_' ~ languageLevel.language.ShortCode)|lower|trans({}, "messages", profile_language) }}
                <sup
                  class="ml-1 gray">{{ ('language.level.' ~ languageLevel.level)|lower|trans({}, "messages", profile_language) }}</sup>
              </p>
            {% else %}
              {{ 'profile.no.languages'|trans({}, 'messages', profile_language) }}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'languages.spoken'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_languages', {username: member.username, language: profile_language}) %}
            {% set edit_text = 'profile.edit.languages'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          <div class="card-text m-0">
            {% for level, languages in member.levelLanguages %}
              <p class="u:font-500 u:text-18 u:font-signika">{{ ('language.level.' ~ level)|lower|trans({}, "messages", profile_language) }}</p>
              <p class="">
                {% for language in languages %}
                  {{ ('lang_' ~ language.ShortCode)|lower|trans({}, "messages", profile_language) }}
                  {%- if loop.index != loop.last %}, {% endif -%}
                {% endfor %}
              </p>
            {% else %}
              {{ 'profile.no.languages'|trans({}, 'messages', profile_language) }}
            {% endfor %}
          </div>
        </div>
      </div>
    </div>

    {# Check if any interests are set #}
    {% set hobbies = profileTranslation['Hobbies'] ?? '' %}
    {% set books = profileTranslation['Books'] ?? '' %}
    {% set music = profileTranslation['Music'] ?? '' %}
    {% set movies = profileTranslation['Movies'] ?? '' %}
    {% set organizations = profileTranslation['Organizations'] ?? '' %}
    {% set interests = hobbies|length != 0 or books|length != 0 or music|length != 0 or movies|length != 0
      or organizations|length != 0 %}

    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.interests'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'interests'}) %}
            {% set edit_text = 'profile.edit.interests'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {% endif %}
        </div>
        <div class="card-block p-2">
          {% if interests or edit %}
            <div class="card-text m-0">
              {% if hobbies|length != 0 or edit %}
                <div class="h5 u:mt-8 u:mb-0">{{ 'profile.hobbies'|trans({}, "messages", profile_language) }}
                </div>
                <div>{{ hobbies|purify }}</div>
              {% endif %}
              {% if books|length != 0 or edit %}
                <div class="h5 u:mt-8 u:mb-0">{{ 'profile.books'|trans({}, "messages", profile_language) }}
                </div>
                <div>{{ books|purify }}</div>
              {% endif %}
              {% if music|length != 0 or edit %}
                <div class="h5 u:mt-8 u:mb-0">{{ 'profile.music'|trans({}, "messages", profile_language) }}
                </div>
                <div>{{ music|purify }}</div>
              {% endif %}
              {% if movies|length != 0 or edit %}
                <div class="h5 u:mt-8 u:mb-0">{{ 'profile.movies'|trans({}, "messages", profile_language) }}
                </div>
                <div>{{ movies|purify }}</div>
              {% endif %}
              {% if organizations|length != 0 or edit %}
                <div class="h5 u:mt-8 u:mb-0">{{ 'profile.organizations'|trans({}, "messages", profile_language) }}
                </div>
                <div>{{ organizations|purify }}</div>
              {% endif %}
            </div>
          {% else %}
            {{ 'profile.no.interests'|trans({}, "messages", profile_language) }}
          {% endif %}
        </div>
      </div>
    </div>


    {# Check if any travel experience is there #}
    {% set pastTrips = profileTranslation['PastTrips'] ?? '' %}
    {% set plannedTrips = profileTranslation['PlannedTrips'] ?? '' %}
    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.travel.experience'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'travels'}) %}
            {% set edit_text = 'profile.edit.travel.experience'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          <div class="card-text m-0">
            {% if pastTrips|length != 0 or edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.past.trips'|trans({}, "messages", profile_language)|raw }}
              </div>
              <div>{{ pastTrips|purify }}</div>
            {% endif %}
            {% if plannedTrips|length != 0 or edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.planned.trips'|trans({}, "messages", profile_language)|raw }}
              </div>
              <div>{{ plannedTrips|purify }}</div>
            {% endif %}
            {% if pastTrips|length == 0 and plannedTrips|length == 0 and not edit %}
              {{ 'profile.no.travel.experiences'|trans({}, 'messages', profile_language) }}
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.groups'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('groups_mygroups') %}
            {% set edit_text = 'profile.edit.groups'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="p-2">
          {% for group in member.groups|slice(0,5) %}
            <div class="mb-3 d-flex d-column">
              <div>
                <a href="{{ url('group_start', {group_id: group.id}) }}">
                  <img class="framed float-left mr-2" width="50" height="50" alt="Group"
                       src="{{ url('group_thumbimg', {group_id: group.id}) }}"/>
                </a>
              </div>
              <div class="text-truncate">
                <h4 class="m-0 text-truncate"><a
                    href="{{ url('group_start', {group_id: group.id}) }}">{{ group.name }}</a>
                </h4>
                <p class="m-0 text-truncate">
                  {% set groupMembership = group.membership(member) %}{{ (groupMembership.comments|first).sentence|purify|truncate(50) }}</p>
              </div>
            </div>
          {% else %}
            {{ 'profile.no.groups'|trans({}, 'messages', profile_language) }}
          {% endfor %}
          {% if member.groups|length > 5 %}
            <a class="btn btn-sm btn-block btn-outline-primary"
               href="{{ url('group_user_all', {username:member.username}) }}">{{ 'groupsallmylink'|trans({}, "messages", profile_language) }}</a>
          {% endif %}
        </div>
      </div>
    </div>

    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.images'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('gallery_manage') %}
            {% set edit_text = 'profile.edit.images'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          {% if pictures|length > 0 %}
            <div class="d-flex flex-wrap justify-content-around">
              {% for picture in pictures %}
                <a href="{{ url('gallery_image', {id: picture.id}) }}"
                   style="max-width: 40%; display: flex; align-items: center; margin-bottom: 1rem;"
                   data-toggle="lightbox"
                   data-gallery="profile-gallery"
                   data-type="image"
                   data-title="{{ picture.title }}">
                  <img
                    src="{{ url('gallery_thumbnail', {id: picture.id, t: 1}) }}"
                    class="img-fluid"
                    alt="{{ picture.title }}"
                  />
                </a>
              {% endfor %}
            </div>
          {% else %}
            {{ 'profile.no.images'|trans({}, 'messages', profile_language) }}
          {% endif %}
        </div>
      </div>
    </div>

    {% if relations|length != 0 %}
      <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
        <div class="card">
          <div
            class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.family.and.friends'|trans({}, "messages", profile_language)|raw }}
            {%- if edit -%}
              {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'relations'}) %}
              {% set edit_text = 'profile.edit.family.and.friends'|trans({}, 'messages', profile_language) %}
              <a href="{{ edit_link }}">
                <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
                <span class="u:sr-only">{{ edit_text }}</span>
              </a>
            {%- endif -%}
          </div>
          <div class="card-block u:p-4">
            <div class="u:grid u:grid-cols-[80px_auto] u:gap-x-8 u:gap-y-12">
              {% for relation in relations|slice(0,10) %}
                <div class="u:flex u:flex-col u:items-center">
                  <div class="o-avatar o-avatar--s u:mr-4">
                    {{ macros.roundedavatarstack(relation.owner.username, 48, false) }}
                  </div>
                  <a href="{{ url('members_profile', {username: relation.owner.username}) }}"
                     class="u:text-[.875em] u:text-center"
                     style="word-break: break-all;">{{ relation.owner.username }}</a>
                </div>
                <div class="u:leading-16">
                  {{ relation.commentText }}
                </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
    {% endif %}

    <div class="u:md:break-inside-avoid u:order-2 u:mb-16 u:break-before-column">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.accommodation'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'accommodation'}) %}
            {% set edit_text = 'profile.edit.accommodation'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          <div class="card-text m-0">
            {% if not member.accommodation is null or edit %}
              {% if edit %}
                {% if not address is same as(false) %}
                  <div class="u:flex u:flex-row u:justify-between align-items-center u:mb-8 u:gap-8">
                    <div>
                      <p class="h5">{{ 'profile.location'|trans({}, 'messages', profile_language) }}</p>
                      <p class="u:font-700">{{ address.location.name }}</p>
                      <p>{{ address.location.admin1.name }} - {{ address.location.country.name }}</p>
                      <a href="{{ url('profile_set_location', {username: member.username}) }}" class="o-button o-button--outline">{{ 'profile.change.location'|trans({}, 'messages', profile_language) }}</a>
                    </div>
                    <div id="location-map-{{ profile_language }}"
                         class="u:w-[40%] u:aspect-3/2 u:border-1 u:border-bewelcome"></div>
                  </div>
                {% endif %}
              {% endif %}
              <div class="u:flex u:flex-row u:justify-between u:mb-8">
                <div>
                  {% if edit or (member.maxGuests != 0 and member.accommodation == constant('App\\Doctrine\\AccommodationType::YES')) %}
                    {% set lastUpdate = member.updated ?? member.created %}
                    <p
                      class="guests h5 u:mb-4">{{ 'profile.max.guests'|trans({}, "messages", profile_language)|raw }} {{ member.maxGuests }}
                      <br>
                      {{ 'profile.hosting_interest'|trans({}, "messages", profile_language)|raw }} {{ macros.hostingInterest(member.hostingInterest, profile_language) }}
                      <br>
                      <span
                        class="u:text-12 u:font-400">{{ 'profile.hosting_interest.last_updated'|trans({updated: lastUpdate}, "messages+intl-icu", profile_language) }}</span>
                    </p>
                  {% else %}
                    {% if member.accommodation == constant('App\\Doctrine\\AccommodationType::NO') %}
                      {{ 'member.not.hosting'|trans({}, "messages", profile_language) }}
                    {% endif %}
                  {% endif %}
                </div>

                <div id="quickinfo" class="U:items-end u:shrink-0">
                  {% if not address is same as(false) and address.isWheelChairAccessible %}
                    <img
                    src="{{ asset('images/icons/wheelchairblue.png') }}" alt="{{ 'wheelchair'|trans({}, "messages", profile_language) }}
                                 title="{{ 'canhostwheelchairyes'|trans({}, "messages", profile_language) }}">
                  {% endif %}
                  <img src="images/icons/{{ member.accommodation }}.png"
                       alt="{{ member.accommodation|trans({}, "messages", profile_language) }}
                                 title="{{ ('canoffer' ~ member.accommodation)|trans({}, "messages", profile_language) }}
                  ">
                </div>
              </div>
            {% else %}
              {{ 'profile.no.accommodation'|trans({}, "messages", profile_language) }}
            {% endif %}

            {% set maxLengthOfStay = profileTranslation['MaxLengthOfStay'] ?? '' %}
            {% if maxLengthOfStay|length != 0 or edit %}
              <div
                class="stay h5 u:mt-8 u:mb-0">{{ 'profile.max.length.of.stay'|trans({}, "messages", profile_language)|raw }}</div>
              {% if maxLengthOfStay|length != 0 %}
                <div>
                  {{ profileTranslation['MaxLengthOfStay']|purify }}
                </div>
              {% endif %}
            {% endif %}

            {% set iLiveWith = profileTranslation['ILiveWith'] ?? '' %}
            {% if iLiveWith|length > 0 or edit %}
              <div
                class="stay h5 u:mt-8 u:mb-0">{{ 'profile.i.live.with'|trans({}, "messages", profile_language)|raw }}</div>
              {% if iLiveWith|length > 0 %}
                <div>{{ profileTranslation['ILiveWith']|purify }}</div>{% endif %}
            {% endif %}

            {% set pleaseBring = profileTranslation['PleaseBring'] ?? '' %}
            {% if pleaseBring|length > 0 or edit %}
              <div
                class="stay h5 u:mt-8 u:mb-0">{{ 'profile.please.bring'|trans({}, "messages", profile_language)|raw }}</div>
              {% if pleaseBring|length > 0 %}
                <div>{{ profileTranslation['PleaseBring']|purify }}</div>{% endif %}
            {% endif %}

            {% set whereYouSleep = profileTranslation['WhereYouSleep'] ?? '' %}
            {% if whereYouSleep|length > 0 or edit %}
              <div
                class="h5 u:mt-8 u:mb-0">{{ 'profile.where.you.sleep'|trans({}, "messages", profile_language)|raw }}</div>
              <div>
                {% if whereYouSleep|length > 0 %}
                  {{ whereYouSleep|purify }}
                {% endif %}
              </div>
            {% endif %}

            {% set standardOffers = member.StandardOffers %}
            {% set offerGuests = profileTranslation['OfferGuests'] ?? '' %}
            {% if standardOffers|length > 0 or offerGuests|length > 0 or edit %}
              <div
                class="h5 u:mt-8 u:mb-0">{{ 'profile.offer.guests'|trans({}, "messages", profile_language)|raw }}</div>
              <div>
                {% for offer in standardOffers %}
                  {{ ('ProfileTypicOffer_' ~ offer)|lower|trans({}, "messages", profile_language) }}
                  <br>
                {% endfor %}
                {% if offerGuests|length > 0 %}
                  {{ offerGuests|purify }}
                {% endif %}
              </div>
            {% endif %}

            {% set additionalInfo = profileTranslation['AdditionalAccommodationInfo'] ?? '' %}
            {% if additionalInfo|length != 0 or edit %}
              <div
                class="h5 u:mt-8 u:mb-0">{{ 'profile.additional.information.for.guests'|trans({}, "messages", profile_language)|raw }}</div>
              {% if additionalInfo|length != 0 %}
                {{ additionalInfo|purify }}
              {% endif %}
            {% endif %}
            {% set gettingThere = profileTranslation['GettingThere'] ?? '' %}
            {% if gettingThere|length != 0 or edit %}
              <div
                class="stay h5 u:mt-8 u:mb-0">{{ 'profile.getting.there'|trans({}, "messages", profile_language)|raw }}</div>
              {% if gettingThere|length != 0 %}
                <div>{{ profileTranslation['GettingThere']|purify }}</div>{% endif %}
            {% endif %}
            {% set restrictions = member.Restrictions %}
            {% set houseRules = profileTranslation['HouseRules'] ?? '' %}
            {% if restrictions|length > 0 or houseRules|length > 0 or edit %}
              <div
                class="h5 u:mt-8">{{ 'profile.house.rules'|trans({}, "messages", profile_language)|raw }}</div>
              <div>
                {% for restriction in restrictions %}
                  {{ ('restriction_' ~ restriction)|lower|trans({}, "messages", profile_language) }}
                  <br>
                {% endfor %}
                {% if houseRules|length > 0 %}
                  {{ houseRules|purify }}
                {% endif %}
              </div>
            {% endif %}

            {% if not edit and member.accommodation == constant('App\\Doctrine\\AccommodationType::YES') %}
              <div>
                <a href="{{ url('hosting_request', {username: member.username}) }}"
                   class="btn btn-primary float-right"><i
                    class="fa fa-bed mr-1"></i>{{ 'profile.request.hosting'|trans({}, "messages", profile_language) }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    </div>

    <div class="u:md:break-inside-avoid u:order-3 u:mb-16">
      <div class="card">
        <div
          class="card-header u:flex u:flex-row u:justify-between">{{ 'profile.comments'|trans({}, "messages", profile_language) }}
          {%- if edit and comments|slice(0,10)|length > 0 -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'comments'}) %}
            {% set edit_text = 'profile.edit.comments'|trans({}, 'messages', profile_language) %}
            <a href="{{ edit_link }}">
              <i class="fa fa-edit" title="{{ edit_text }}" aria-hidden="true"></i>
              <span class="u:sr-only">{{ edit_text }}</span>
            </a>
          {%- endif -%}
        </div>
        <div class="card-block p-2">
          {% set commentsShown = 0 %}
          {% for comment in comments|slice(0,10) %}
            {% set commentToVisible = (comment['to'] is defined) ? (comment['to'].showCondition(app.user) > 0) : false %}
            {% set commentFromVisible = (comment['from'] is defined) ? (comment['from'].showCondition(app.user) > 0) : false %}
            {% if commentToVisible or commentFromVisible %}
              {% set commentsShown = commentsShown + 1 %}
              {% include 'profile/comment.embedded.html.twig' with { comment: comment, language: profile_language } %}
            {% endif %}
          {% else %}
            {{ 'profile.no.comments'|trans({}, 'messages', profile_language) }}
          {% endfor %}
          {% if comments|length != visibleComments %}
            <a href="{{ url('profile_comments', {username: member.username}) }}"
               class="btn btn-block btn-sm btn-outline-primary">
              {{ 'showallcomments'|trans({}, "messages", profile_language) }} <span
                class="badge badge-primary u:rounded-8 u:px-8 u:min-w-20">{{ visibleComments }}</span>
            </a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
  {% if edit and profile_language != 'en' %}
    <div class="u:flex u:my-8 u:justify-end">
      <button type="button" data-delete-language="{{ profile_language }}" class="o-button">
        {{ 'profile.language.delete'|trans({}, "messages", profile_language) }}
        - {{ ('lang_' ~ profile_language)|trans({}, "messages", profile_language) }}
      </button>
    </div>
    <div class="micromodal-slide" id="delete-{{ profile_language }}">
      <div class="modal__overlay u:bg-gray-100/50 u:flex u:justify-center u:absolute u:inset-0 u:z-[2001]">
        <div class="u:bg-white u:p-16 u:m-16 u:rounded-8 u:min-w-50  u:w-max-[80%] u:sm:w-max-[60%] u:md:w-max-[50%] ">
          <div class="u:mb-16">
            <p class="u:text-24 u:mb-8 u:font-700 u:text-center">{{ 'profile.language.delete.modal'|trans }}</p>
            <p class="u:text-16">{{ 'profile.language.delete.blurb'|trans }} some extra text... some extra text</p>
          </div>
          <div class="u:flex u:flex-row u:w-full u:justify-between">
            <a class="o-button"
               data-micromodal-close>{{ 'language.delete.no'|trans({}, "messages", profile_language) }}</a>
            <a class="o-button"
               href="{{ url('profile_delete_language', {username: member.username, language: profile_language}) }}">
              {{ 'language.delete.yes'|trans({}, "messages", profile_language) }}
            </a>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
