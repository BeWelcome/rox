{% import 'macros.twig' as macros %}

{% set address = member.activeAddress %}
{% set profileTranslation = translated_fields[profile_language] ?? [] %}
{% set aboutMe = profileTranslation['AboutMe'] ?? '' %}
{% set occupation = profileTranslation['Occupation'] ?? '' %}
{% set offerHosts = profileTranslation['OfferHosts'] ?? '' %}
{% set hobbies = profileTranslation['Hobbies'] ?? '' %}
{% set books = profileTranslation['Books'] ?? '' %}
{% set music = profileTranslation['Music'] ?? '' %}
{% set movies = profileTranslation['Movies'] ?? '' %}
{% set organizations = profileTranslation['Organizations'] ?? '' %}
{% set interests = hobbies|length != 0 or books|length != 0 or music|length != 0 or movies|length != 0 or organizations|length != 0 %}
{% set pastTrips = profileTranslation['PastTrips'] ?? '' %}
{% set plannedTrips = profileTranslation['PlannedTrips'] ?? '' %}
{% set maxLengthOfStay = profileTranslation['MaxLengthOfStay'] ?? '' %}
{% set iLiveWith = profileTranslation['ILiveWith'] ?? '' %}
{% set pleaseBring = profileTranslation['PleaseBring'] ?? '' %}
{% set whereYouSleep = profileTranslation['WhereYouSleep'] ?? '' %}
{% set standardOffers = member.StandardOffers %}
{% set offerGuests = profileTranslation['OfferGuests'] ?? '' %}
{% set additionalInfo = profileTranslation['AdditionalAccommodationInfo'] ?? '' %}
{% set gettingThere = profileTranslation['GettingThere'] ?? '' %}
{% set restrictions = member.Restrictions %}
{% set houseRules = profileTranslation['HouseRules'] ?? '' %}

<div id="profile-language-{{ profile_language }}"
     class="{% if profile_language != active_locale %}u:hidden! {% endif %}">
  <div class="p-profile-layout{% if edit %} p-profile-layout--edit{% endif %}">

    {# ═══════════════════════════════════════════
       MAIN — About Me · Accommodation · Comments
       ═══════════════════════════════════════════ #}
    <div class="p-profile-main">

      {# ── About Me ────────────────────────────── #}
      {% if aboutMe|length > 0 or offerHosts|length > 0 or edit %}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.about.me'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'aboutme'}) %}
            {% set edit_text = 'profile.edit.about.me'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        <div class="card-body">
          <div class="card-text m-0">
            {% if aboutMe|length != 0 %}
              {{ aboutMe|purify|nl2br }}
            {% elseif edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.about.me'|trans({}, "messages", profile_language)|raw }}</div>
            {% endif %}
            {% if edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.occupation'|trans({}, "messages", profile_language)|raw }}</div>
              <div>{% if occupation|length != 0 %}{{ occupation|purify|nl2br }}{% endif %}</div>
            {% endif %}
          </div>
          {% if offerHosts|length > 0 or edit %}
            <div class="stay h5 u:mt-8 u:mb-0">{{ 'profile.offer.hosts'|trans({}, "messages", profile_language)|raw }}</div>
            {% if offerHosts|length > 0 %}<div>{{ profileTranslation['OfferHosts']|purify }}</div>{% endif %}
          {% endif %}
        </div>
      </div>
      {% endif %}

      {# ── Accommodation ───────────────────────── #}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.accommodation'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'accommodation'}) %}
            {% set edit_text = 'profile.edit.accommodation'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        <div class="card-body">
          <div class="card-text m-0">
            {% if not member.accommodation is null or edit %}
              {% if edit and not address is same as(false) %}
                <section class="p-accom-summary">
                  <div class="p-accom-summary__info">
                    <span class="p-accom-summary__eyebrow">
                      <i class="fas fa-map-marker-alt" aria-hidden="true"></i>
                      {{ 'profile.location'|trans({}, 'messages', profile_language) }}
                    </span>
                    <h3 class="p-accom-summary__city">{{ address.location.name }}</h3>
                    <p class="p-accom-summary__region">{{ address.location.admin1.name }} · {{ address.location.country.name }}</p>
                    <a href="{{ url('profile_set_location', {username: member.username}) }}" class="p-accom-summary__change">
                      <i class="fas fa-location-arrow" aria-hidden="true"></i>
                      {{ 'profile.change.location'|trans({}, 'messages', profile_language) }}
                    </a>
                  </div>
                  <div id="location-map-{{ profile_language }}" class="p-accom-summary__map" aria-label="{{ 'profile.location'|trans({}, 'messages', profile_language) }}"></div>
                </section>
              {% endif %}
              <div class="p-accom-stats u:mb-8">
                {% if edit or (member.maxGuests != 0 and member.accommodation == constant('App\\Doctrine\\AccommodationType::YES')) %}
                  {% set lastUpdate = member.updated ?? member.created %}
                  <div class="p-accom-chips">
                    <span class="p-accom-chip">
                      <i class="fas fa-user-friends"></i>
                      {{ 'profile.max.guests'|trans({}, "messages", profile_language)|raw }} <strong>{{ member.maxGuests }}</strong>
                    </span>
                    <span class="p-accom-chip">
                      <i class="fas fa-star"></i>
                      {{ 'profile.hosting_interest'|trans({}, "messages", profile_language)|raw }} <strong>{{ macros.hostingInterest(member.hostingInterest, profile_language) }}</strong>
                    </span>
                    {% if not address is same as(false) and address.isWheelChairAccessible %}
                      <span class="p-accom-chip p-accom-chip--access" title="{{ 'canhostwheelchairyes'|trans({}, "messages", profile_language) }}">
                        <i class="fas fa-wheelchair"></i> {{ 'wheelchair'|trans({}, "messages", profile_language) }}
                      </span>
                    {% endif %}
                  </div>
                  <p class="p-accom-updated">
                    <i class="fas fa-clock"></i>
                    {{ 'profile.hosting_interest.last_updated'|trans({updated: lastUpdate}, "messages+intl-icu", profile_language) }}
                  </p>
                {% else %}
                  {% if member.accommodation == constant('App\\Doctrine\\AccommodationType::NO') %}
                    <p class="u:m-0">{{ 'member.not.hosting'|trans({}, "messages", profile_language) }}</p>
                  {% endif %}
                {% endif %}
              </div>
            {% else %}
              <p class="u:m-0">{{ 'profile.no.accommodation'|trans({}, "messages", profile_language) }}</p>
            {% endif %}

            {% if maxLengthOfStay|length != 0 or edit %}
              <div class="stay h5 u:mt-8 u:mb-0">{{ 'profile.max.length.of.stay'|trans({}, "messages", profile_language)|raw }}</div>
              {% if maxLengthOfStay|length != 0 %}<div>{{ profileTranslation['MaxLengthOfStay']|purify }}</div>{% endif %}
            {% endif %}
            {% if iLiveWith|length > 0 or edit %}
              <div class="stay h5 u:mt-8 u:mb-0">{{ 'profile.i.live.with'|trans({}, "messages", profile_language)|raw }}</div>
              {% if iLiveWith|length > 0 %}<div>{{ profileTranslation['ILiveWith']|purify }}</div>{% endif %}
            {% endif %}
            {% if pleaseBring|length > 0 or edit %}
              <div class="stay h5 u:mt-8 u:mb-0">{{ 'profile.please.bring'|trans({}, "messages", profile_language)|raw }}</div>
              {% if pleaseBring|length > 0 %}<div>{{ profileTranslation['PleaseBring']|purify }}</div>{% endif %}
            {% endif %}
            {% if whereYouSleep|length > 0 or edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.where.you.sleep'|trans({}, "messages", profile_language)|raw }}</div>
              <div>{% if whereYouSleep|length > 0 %}{{ whereYouSleep|purify }}{% endif %}</div>
            {% endif %}
            {% if standardOffers|length > 0 or offerGuests|length > 0 or edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.offer.guests'|trans({}, "messages", profile_language)|raw }}</div>
              <div>
                {% for offer in standardOffers %}{{ ('ProfileTypicOffer_' ~ offer)|lower|trans({}, "messages", profile_language) }}<br>{% endfor %}
                {% if offerGuests|length > 0 %}{{ offerGuests|purify }}{% endif %}
              </div>
            {% endif %}
            {% if additionalInfo|length != 0 or edit %}
              <div class="h5 u:mt-8 u:mb-0">{{ 'profile.additional.information.for.guests'|trans({}, "messages", profile_language)|raw }}</div>
              {% if additionalInfo|length != 0 %}{{ additionalInfo|purify }}{% endif %}
            {% endif %}
            {% if gettingThere|length != 0 or edit %}
              <div class="stay h5 u:mt-8 u:mb-0">{{ 'profile.getting.there'|trans({}, "messages", profile_language)|raw }}</div>
              {% if gettingThere|length != 0 %}<div>{{ profileTranslation['GettingThere']|purify }}</div>{% endif %}
            {% endif %}
            {% if restrictions|length > 0 or houseRules|length > 0 or edit %}
              <div class="h5 u:mt-8">{{ 'profile.house.rules'|trans({}, "messages", profile_language)|raw }}</div>
              <div>
                {% for restriction in restrictions %}{{ ('restriction_' ~ restriction)|lower|trans({}, "messages", profile_language) }}<br>{% endfor %}
                {% if houseRules|length > 0 %}{{ houseRules|purify }}{% endif %}
              </div>
            {% endif %}

            {% if not edit and app.user != member and member.accommodation == constant('App\\Doctrine\\AccommodationType::YES') %}
              <div class="p-accom-cta">
                <a href="{{ url('hosting_request', {username: member.username}) }}" class="p-hero__btn p-hero__btn--primary">
                  <i class="fas fa-bed"></i> {{ 'profile.request.hosting'|trans({}, "messages", profile_language) }}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>

      {# ── Comments (hidden in edit mode: not editable content) ── #}
      {% if not edit %}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.comments'|trans({}, "messages", profile_language) }}
        </div>
        <div class="card-body">
          {% if comments|length > 0 %}
            <div class="p-comments-counts">
              <a href="{{ url('profile_comments', {username: member.username, type: 'positive'}) }}" class="p-comments-count p-comments-count--positive">
                <i class="fas fa-thumbs-up"></i> {{ comments_count.positive }}
              </a>
              <a href="{{ url('profile_comments', {username: member.username, type: 'neutral'}) }}" class="p-comments-count p-comments-count--neutral">
                <i class="fas fa-minus"></i> {{ comments_count.neutral }}
              </a>
              <a href="{{ url('profile_comments', {username: member.username, type: 'negative'}) }}" class="p-comments-count p-comments-count--negative">
                <i class="fas fa-thumbs-down"></i> {{ comments_count.negative }}
              </a>
            </div>
          {% endif %}
          {% set commentsShown = 0 %}
          {% for comment in comments|slice(0,10) %}
            {% set commentToVisible = (comment['to'] is defined) ? (comment['to'].showCondition(app.user) > 0) : false %}
            {% set commentFromVisible = (comment['from'] is defined) ? (comment['from'].showCondition(app.user) > 0) : false %}
            {% if commentToVisible or commentFromVisible %}
              {% set commentsShown = commentsShown + 1 %}
              {% include 'profile/comment.embedded.html.twig' with { comment: comment, language: profile_language } %}
            {% endif %}
          {% else %}
            <div class="p-no-comments">
              <i class="fas fa-comment-slash"></i>
              <p>{{ 'profile.no.comments'|trans({}, 'messages', profile_language) }}</p>
            </div>
          {% endfor %}
          {% if comments|length != visibleComments %}
            <a href="{{ url('profile_comments', {username: member.username}) }}" class="btn btn-block btn-sm btn-outline-primary">
              {{ 'showallcomments'|trans({}, "messages", profile_language) }} <span class="badge text-bg-primary u:rounded-8 u:px-8 u:min-w-20">{{ visibleComments }}</span>
            </a>
          {% endif %}
          {% if not edit and submenu.items is defined and submenu.items.comment is defined %}
            <div class="p-accom-cta">
              <a href="{{ submenu.items.comment.url }}" class="p-hero__btn p-hero__btn--outline">
                <i class="fas fa-comment"></i> {{ submenu.items.comment.key|lower|trans }}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
      {% endif %}

    </div>{# /.p-profile-main #}

    {# ═══════════════════════════════════════════════════════
       SECONDARY — Languages · Interests · Travel · Groups · Gallery · Friends
       ═══════════════════════════════════════════════════════ #}
    <div class="p-profile-secondary">

      {# ── Languages ───────────────────────────── #}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'languages.spoken'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_languages', {username: member.username, language: profile_language}) %}
            {% set edit_text = 'profile.edit.languages'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        <div class="card-body">
          <div class="card-text m-0">
            {% for level, languages in member.levelLanguages %}
              <p class="p-sidebar-card__lang-level">{{ ('language.level.' ~ level)|lower|trans({}, "messages", profile_language) }}</p>
              <p class="p-sidebar-card__lang-list">
                {% for language in languages %}{{ ('lang_' ~ language.ShortCode)|lower|trans({}, "messages", profile_language) }}{%- if loop.index != loop.last %}, {% endif -%}{% endfor %}
              </p>
            {% else %}
              <p class="u:m-0">{{ 'profile.no.languages'|trans({}, 'messages', profile_language) }}</p>
            {% endfor %}
          </div>
        </div>
      </div>

      {# ── Interests ───────────────────────────── #}
      {% if interests or edit %}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.interests'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'interests'}) %}
            {% set edit_text = 'profile.edit.interests'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {% endif %}
        </div>
        {% if interests %}
        <div class="card-body">
          <div class="card-text m-0">
            {% if hobbies|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.hobbies'|trans({}, "messages", profile_language) }}</div><div>{{ hobbies|purify }}</div>{% endif %}
            {% if books|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.books'|trans({}, "messages", profile_language) }}</div><div>{{ books|purify }}</div>{% endif %}
            {% if music|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.music'|trans({}, "messages", profile_language) }}</div><div>{{ music|purify }}</div>{% endif %}
            {% if movies|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.movies'|trans({}, "messages", profile_language) }}</div><div>{{ movies|purify }}</div>{% endif %}
            {% if organizations|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.organizations'|trans({}, "messages", profile_language) }}</div><div>{{ organizations|purify }}</div>{% endif %}
          </div>
        </div>
        {% endif %}
      </div>
      {% endif %}

      {# ── Travel Experience ───────────────────── #}
      {% if pastTrips|length > 0 or plannedTrips|length > 0 or edit %}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.travel.experience'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'travels'}) %}
            {% set edit_text = 'profile.edit.travel.experience'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        {% if pastTrips|length > 0 or plannedTrips|length > 0 %}
        <div class="card-body">
          <div class="card-text m-0">
            {% if pastTrips|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.past.trips'|trans({}, "messages", profile_language)|raw }}</div><div>{{ pastTrips|purify }}</div>{% endif %}
            {% if plannedTrips|length != 0 or edit %}<div class="h5 u:mt-8 u:mb-0">{{ 'profile.planned.trips'|trans({}, "messages", profile_language)|raw }}</div><div>{{ plannedTrips|purify }}</div>{% endif %}
          </div>
        </div>
        {% endif %}
      </div>
      {% endif %}

      {# ── Groups ──────────────────────────────── #}
      {% if member.groups|length > 0 or edit %}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.groups'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('groups_mygroups') %}
            {% set edit_text = 'profile.edit.groups'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        {% if member.groups|length > 0 %}
        <div class="card-body">
          {% for group in member.groups|slice(0, 5) %}
            <div class="p-sidebar-card__group-item">
              <a href="{{ url('group_start', {group_id: group.id}) }}">
                <img width="38" height="38" alt="Group" src="{{ url('group_thumbimg', {group_id: group.id}) }}">
              </a>
              <a class="p-sidebar-card__group-name" href="{{ url('group_start', {group_id: group.id}) }}">{{ group.name }}</a>
            </div>
          {% endfor %}
          {% if member.groups|length > 5 %}
            <a class="p-sidebar-card__more-link" href="{{ url('group_user_all', {username: member.username}) }}">
              {{ 'groupsallmylink'|trans({}, "messages", profile_language) }}
              <span class="p-sidebar-card__count-badge">{{ member.groups|length }}</span>
            </a>
          {% endif %}
        </div>
        {% endif %}
      </div>
      {% endif %}

      {# ── Gallery ─────────────────────────────── #}
      {% if pictures|length > 0 or edit %}
      <div class="card p-gallery-card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.menu.images'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_text = 'profile.edit.images'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ url('gallery_manage') }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        {% if pictures|length == 0 and edit %}
          <div class="p-gallery-empty">
            <a href="{{ url('gallery_manage') }}" class="p-gallery-empty__btn">
              <i class="fas fa-cloud-upload-alt" aria-hidden="true"></i>
              <span>{{ 'galleryupload'|trans({}, 'messages', profile_language) }}</span>
            </a>
          </div>
        {% else %}
        <div class="p-gallery-grid">
          {% for picture in pictures|slice(0, 5) %}
            {% set isLast = loop.last and pictures|length > 5 %}
            {% if isLast %}
              <a href="{{ url('gallery', {username: member.username}) }}"
                 class="p-gallery-cell p-gallery-cell--more"
                 style="background-image: url('{{ url('gallery_thumbnail', {id: picture.id, t: 2}) }}')"
                 aria-label="{{ picture.title|e('html_attr') }}">
                <span class="p-gallery-cell__more-label">+{{ pictures|length - 4 }}</span>
              </a>
            {% else %}
              <a href="{{ url('gallery_image', {id: picture.id}) }}"
                 class="p-gallery-cell"
                 style="background-image: url('{{ url('gallery_thumbnail', {id: picture.id, t: 2}) }}')"
                 data-toggle="lightbox"
                 data-gallery="profile-gallery"
                 data-type="image"
                 data-caption="{{ picture.title|e('html_attr') }}"
                 aria-label="{{ picture.title|e('html_attr') }}"></a>
            {% endif %}
          {% endfor %}
        </div>
        {% endif %}
        {% if pictures|length > 5 %}
          <div class="p-gallery-footer">
            <a href="{{ url('gallery', {username: member.username}) }}">
              {{ 'profile.all.images'|trans({}, "messages", profile_language) }}
              <span class="p-gallery-footer__count">{{ pictures|length }}</span>
            </a>
          </div>
        {% endif %}
      </div>
      {% endif %}

      {# ── Friends ─────────────────────────────── #}
      {% if friends|length > 0 or edit %}
      <div class="card">
        <div class="card-header u:flex u:flex-row u:justify-between">
          {{ 'profile.family.and.friends'|trans({}, "messages", profile_language)|raw }}
          {%- if edit -%}
            {% set edit_link = url('profile_edit_section', {username: member.username, language: profile_language, section: 'relations'}) %}
            {% set edit_text = 'profile.edit.family.and.friends'|trans({}, 'messages', profile_language) %}
            <div><a href="{{ edit_link }}"><i class="fas fa-edit" title="{{ edit_text }}" aria-hidden="true"></i><span class="visually-hidden">{{ edit_text }}</span></a></div>
          {%- endif -%}
        </div>
        {% if friends|length > 0 %}
        <div class="card-body">
          <div class="u:grid u:grid-cols-3 u:gap-8 u:mb-8">
            {% for friend in friends|slice(0, 9) %}
              {% set other = friend.left == member ? friend.right : friend.left %}
              <div class="u:flex u:flex-col u:items-center">
                <div class="o-avatar o-avatar--s u:me-4">{{ macros.roundedavatarstack(other.username, 48, false) }}</div>
                <a href="{{ url('members_profile', {username: other.username}) }}" class="u:text-[.875em] u:text-center" style="word-break: break-all;">{{ other.username }}</a>
              </div>
            {% endfor %}
          </div>
          {% if friends|length > 9 %}
            <a href="{{ url('friends', {username: member.username}) }}" class="btn btn-block btn-sm btn-outline-primary">
              {{ 'profile.all.friends'|trans({}, "messages", profile_language) }} <span class="badge text-bg-primary u:rounded-8 u:px-8 u:min-w-20">{{ friends|length }}</span>
            </a>
          {% endif %}
        </div>
        {% endif %}
      </div>
      {% endif %}

    </div>{# /.p-profile-secondary #}

  </div>{# /.p-profile-layout #}

  {% if edit and profile_language != 'en' %}
    <div class="u:flex u:my-8 u:justify-end">
      <button type="button" data-delete-language="{{ profile_language }}" class="o-button">
        {{ 'profile.language.delete'|trans({}, "messages", profile_language) }}
        - {{ ('lang_' ~ profile_language)|trans({}, "messages", profile_language) }}
      </button>
    </div>
    <div class="micromodal-slide" id="delete-{{ profile_language }}">
      <div class="modal__overlay u:bg-gray-100/50 u:flex u:justify-center u:absolute u:inset-0 u:z-[2001]">
        <div class="u:bg-white u:p-16 u:m-16 u:rounded-8 u:min-w-50 u:w-max-[80%] u:sm:w-max-[60%] u:md:w-max-[50%]">
          <div class="u:mb-16">
            <p class="u:text-24 u:mb-8 u:font-700 u:text-center">{{ 'profile.language.delete.modal'|trans }}</p>
            <p class="u:text-16">{{ 'profile.language.delete.blurb'|trans }} some extra text... some extra text</p>
          </div>
          <div class="u:flex u:flex-row u:w-full u:justify-between">
            <a class="o-button" data-micromodal-close>{{ 'language.delete.no'|trans({}, "messages", profile_language) }}</a>
            <a class="o-button" href="{{ url('profile_delete_language', {username: member.username, language: profile_language}) }}">{{ 'language.delete.yes'|trans({}, "messages", profile_language) }}</a>
          </div>
        </div>
      </div>
    </div>
  {% endif %}
</div>
