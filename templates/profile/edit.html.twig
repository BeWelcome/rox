{% extends 'base.html.twig' %}
{% import 'macros.twig' as macros %}

{% block title %}{{ 'profile.title'|trans({username:member.Username}) }}{% endblock %}

{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('readmore') }}
  {{ encore_entry_script_tags('lightbox') }}
  {{ encore_entry_script_tags('profile/profile') }}
  {{ encore_entry_script_tags('profile/edit') }}
{% endblock javascripts %}

{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('readmore') }}
  {{ encore_entry_link_tags('lightbox') }}
  {{ encore_entry_link_tags('leaflet') }}
  {{ encore_entry_link_tags('profile/edit') }}
{% endblock %}

{% block content %}
    {% set translated_fields = member.translations %}
    {% set profile_languages = translated_fields|keys %}
    {% if not language is null %}
        {% set active_locale = language in profile_languages ? language : 'en' %}
    {% else %}
        {% set active_locale = locale in profile_languages ? locale : 'en' %}
    {% endif %}

    {% set address = member.activeAddress %}
    {% if not address is same as(false) %}
      <input type="hidden" id="latitude" value="{{ address.latitude }}"><input type="hidden" id="longitude" value="{{ address.longitude }}">
    {% endif %}

    {% include 'profile/edit.header.html.twig' with {profile_languages: profile_languages, active_locale: active_locale} %}

    {% for profile_language in profile_languages %}
        {% include 'profile/content.html.twig' with {profile_language: profile_language, translated_fields: translated_fields, active_locale:active_locale, edit:true} %}
    {% endfor %}
{% endblock content %}
