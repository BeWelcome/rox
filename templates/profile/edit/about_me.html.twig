{% extends 'profile/edit_subpage.html.twig' %}
{% import 'macros.twig' as macros %}

{% block subpage_title -%}
  {{ 'profile.about.me'|trans({}, 'messages', language)|raw }} · {{ ('lang_' ~ language)|lower|trans({}, 'messages', language) }}
{%- endblock %}

{% block subpage_body %}
  {{ form_start(form) }}

  {% set username = member.username %}
  {% set translations = member.translations %}
  {{ macros.field_translation(form.about_me, locale, language, 'AboutMe', username, translations) }}
  {{ macros.field_translation(form.occupation, locale, language, 'Occupation', username, translations) }}
  {{ macros.field_translation(form.offer_hosts, locale, language, 'OfferHosts', username, translations) }}

  <div class="p-edit-subpage__actions">
    <input type="submit" class="o-button" value="{{ 'save'|trans({}, 'messages', language) }}">
  </div>
  {{ form_end(form) }}
{% endblock subpage_body %}
