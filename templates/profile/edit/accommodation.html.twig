{% extends 'profile/profile.html.twig' %}
{% import 'macros.twig' as macros %}

{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('roxeditor') }}
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('roxeditor') }}
{% endblock %}

{% block page_content %}
  <div class="u:w-full">
    <div class="card">
      <div class="card-header u:flex u:flex-row u:justify-between">
        {{ 'profilesummary'|trans({}, "messages", language)|raw }}
      </div>
      <div class="card-block p-2">
        <div class="card-text">
          {{ form_start(form) }}

          {{ form_row(form.max_guests) }}

          {{ form_label(form.length_of_stay) }}
          {{ form_widget(form.length_of_stay) }}
          {{ macros.field_english(language, 'MaxLengthOfStay', member.translations) }}

          {{ form_label(form.i_live_with) }}
          {{ form_widget(form.i_live_with) }}
          {{ macros.field_english(language, 'ILiveWith', member.translations) }}

          {{ form_label(form.please_bring) }}
          {{ form_widget(form.please_bring) }}
          {{ macros.field_english(language, 'PleaseBring', member.translations) }}

          {{ form_label(form.where_you_sleep) }}
          {{ form_widget(form.where_you_sleep) }}
          {{ macros.field_english(language, 'WhereYouSleep', member.translations) }}

          {{ form_label(form.offer_guests) }}
          {{ form_widget(form.offer_guests) }}
          {{ macros.field_english(language, 'OfferGuests', member.translations) }}

          {{ form_label(form.additional_info) }}
          {{ form_widget(form.additional_info) }}
          {{ macros.field_english(language, 'AdditionalInfo', member.translations) }}

          {{ form_label(form.transport) }}
          {{ form_widget(form.transport) }}
          {{ macros.field_english(language, 'PublicTransport', member.translations) }}

          {{ form_label(form.house_rules) }}
          {{ form_widget(form.house_rules) }}
          {{ macros.field_english(language, 'OtherRestrictions', member.translations) }}

          <div class="u:flex u:justify-end u:my-8">
            <input type="submit" class="o-button" value="{{ 'profile.update'|trans({}, "messages", language) }} - {{ ('lang_' ~ language)|trans({}, "messages", language) }}">
          </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
{% endblock page_content %}
