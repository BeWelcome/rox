{% extends 'profile/edit_subpage.html.twig' %}
{% import 'macros.twig' as macros %}

{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('profile/edit_languages') }}
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('profile/edit_languages') }}
{% endblock %}

{% macro widget_prototype(widget) %}
  {% set form = widget %}
  {% set name = widget.vars.full_name %}
  {% set currentLanguage = name %}
  <div class="p-language-row" id="{{ currentLanguage }}">
    <div class="p-language-row__fields">
      <div class="p-language-form__group">
        {{ form_label(form.language, null, {label_attr: {class: 'p-language-form__label'}}) }}
        {{ form_widget(form.language) }}
        {{ form_errors(form.language) }}
      </div>
      <div class="p-language-form__group {% if form.level.vars.errors|length != 0 %}is-invalid{% endif %}">
        {{ form_label(form.level, null, {label_attr: {class: 'p-language-form__label'}}) }}
        {{ form_widget(form.level) }}
        {{ form_errors(form.level) }}
      </div>
    </div>
    <button type="button" class="p-language-row__delete js-delete-language"
            data-collection-holder-class="collection-languages"
            data-related="{{ currentLanguage }}"
            aria-label="Delete language">
      <i class="fas fa-fw fa-trash" aria-hidden="true"></i>
    </button>
  </div>
{% endmacro %}

{% block subpage_title -%}
  {{ 'profile.languages'|trans|raw }}
{%- endblock %}

{% block subpage_body %}
  {{ form_start(form, {attr: {class: 'p-language-form'}}) }}
  {{ form_errors(form) }}
  <div class="collection-languages"
       data-index="{{ form.language_levels|length > 0 ? form.language_levels|last.vars.name + 1 : 0 }}"
       data-prototype="{{ _self.widget_prototype(form.language_levels.vars.prototype)|e('html_attr') }}">
    {% for language_level in form.language_levels %}
      {% set currentLanguage = language_level.vars.full_name %}
      <div class="p-language-row" id="{{ currentLanguage }}">
        <div class="p-language-row__fields">
          <div class="p-language-form__group">
            {{ form_label(language_level.language, null, {label_attr: {class: 'p-language-form__label'}}) }}
            {{ form_widget(language_level.language) }}
            {{ form_errors(language_level.language) }}
          </div>
          <div class="p-language-form__group {% if language_level.level.vars.errors|length != 0 %}is-invalid{% endif %}">
            {{ form_label(language_level.level, null, {label_attr: {class: 'p-language-form__label'}}) }}
            {{ form_widget(language_level.level) }}
            {{ form_errors(language_level.level) }}
          </div>
        </div>
        <button type="button" class="p-language-row__delete js-delete-language"
                data-collection-holder-class="collection-languages"
                data-related="{{ currentLanguage }}"
                aria-label="Delete language">
          <i class="fas fa-fw fa-trash" aria-hidden="true"></i>
        </button>
      </div>
    {% endfor %}
  </div>

  <div class="p-edit-subpage__actions p-edit-subpage__actions--split">
    <button type="button" class="p-language-add js-add-language"
            data-collection-holder-class="collection-languages">
      <i class="fas fa-fw fa-plus" aria-hidden="true"></i>
      <span>Add language</span>
    </button>
    <input type="submit" class="o-button" value="{{ 'save'|trans }}">
  </div>
  {{ form_rest(form) }}
  {{ form_end(form) }}
{% endblock subpage_body %}
