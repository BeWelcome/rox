{% extends 'profile/profile.html.twig' %}
{% import 'macros.twig' as macros %}

{% block javascripts %}
  {{ parent() }}
  {{ encore_entry_script_tags('roxeditor') }}
{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  {{ encore_entry_link_tags('roxeditor') }}
{% endblock %}

{% block page_content %}
  <div class="u:w-full">
    <div class="card">
      <div class="card-header u:flex u:flex-row u:justify-between">
        {{ 'profilesummary'|trans({}, "messages", language)|raw }}
      </div>
      <div class="card-block p-2">
        <div class="card-text">
          {{ form_start(form) }}
          {{ form_label(form.past) }}
          {{ form_widget(form.past) }}
          {{ macros.field_english(language, 'PastTrips', member.translations) }}

          {{ form_label(form.planned) }}
          {{ form_widget(form.planned) }}
          {{ macros.field_english(language, 'PlannedTrips', member.translations) }}

          <div class="u:flex u:justify-end u:my-8">
            <input type="submit" class="o-button" value="{{ 'profile.update'|trans({}, "messages", language) }} - {{ ('lang_' ~ language)|trans({}, "messages", language) }}">
          </div>
          {{ form_end(form) }}
        </div>
      </div>
    </div>
  </div>
{% endblock page_content %}
